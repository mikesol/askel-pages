---
import Layout from '../layouts/Layout.astro'

const trustItems = [
  {
    icon: '/icons/Artboard_11.svg',
    title: 'Vuodesta 1967',
    desc: 'Lähes 60 vuotta pesulakokemusta Turussa.',
    special: false,
  },
  {
    icon: '/icons/Artboard_7.svg',
    title: 'Paikallinen palveluntarjoaja',
    desc: 'Turku, Raisio, Naantali ja lähikunnat.',
    special: false,
  },
  {
    icon: '/icons/Artboard_3.svg',
    title: 'Aina tavoitettavissa',
    desc: null,
    special: true,
  },
  {
    icon: '/icons/Artboard_9.svg',
    title: 'Joustava palvelu',
    desc: 'Myymälä Turussa tai nouto kotioveltasi.',
    special: false,
  },
]

const steps = [
  { num: '01', title: 'Tilaa palvelu', desc: 'Varaa aika verkossa tai soittamalla. Kerro tarpeesi — räätälöimme palvelun sinulle.' },
  { num: '02', title: 'Nouto kotioveltasi', desc: 'Noudamme tekstiilit sovittuna aikana suoraan oveltasi Turussa.' },
  { num: '03', title: 'Toimitetaan puhtaana', desc: 'Puhdistetut ja viimeistellyt tekstiilit toimitetaan takaisin. Valmis 4–8 päivässä.' },
]

const services = [
  { icon: '/icons/Artboard_2.svg', title: 'Pyykinpesu', desc: 'Arjen tekstiileille hellävaraista ja tehokasta pesua. Paidat, lakanat, pyyhkeet, peitot ja matot — kaikki puhtaana kotiovellesi.', highlight: false },
  { icon: '/icons/Artboard_9.svg', title: 'Kemiallinen pesu', desc: 'Puvut, juhlavaatteet, takit ja silkki — herkät vaatteet käsitelty oikein, muoto ja väri säilyvät.', highlight: false },
  { icon: '/icons/Artboard_4.svg', title: 'Yrityspalvelut', desc: 'Luotettavat pesulapalvelut yrityksille ja yhteisöille. Hoivakodit, hotellit ja ravintolat — sujuvasti hoidettu.', highlight: true },
]

const testimonials = [
  { quote: 'Vein juhlamekkoni kemialliseen pesuun ennen sisareni häitä. Mekossa oli pieni tahranäkymä kainalon kohdalla josta olin huolissani. Tuli takaisin täysin puhtaana ja viimeistelty huolellisesti. Ei muuhun pesulaan enää.', name: 'Reetta S.', location: 'Turku' },
  { quote: 'Matot olivat jo sen verran likaiset etten itse uskaltanut pestä niitä. Soitin Melersille, he neuvoivat miten toimia ja nouto sovittiin samalle viikolle. Matot tulivat takaisin kuin uusina. Hinta oli myös kohtuullinen.', name: 'Pekka V.', location: 'Turku' },
  { quote: 'Tilasin noutopalvelun äidilleni joka asuu Raisiossa. Lakanat ja pyyhkeet haetaan kerran kuukaudessa ja tuodaan puhtaina takaisin. Äiti sanoo ettei jaksa enää pestä itse, ja tämä on ollut todella helppo ratkaisu. Henkilökunta on ystävällistä ja aina täsmällisiä.', name: 'Tuula H.', location: 'Raisio' },
]

const year = new Date().getFullYear()
---

<Layout title="Melers Pesulapalvelut — Kotiovelle. Puhtaana.">
  <link rel="preload" as="image" href="/hero-new.webp" slot="head" />

  <!-- Hero -->
  <section id="etusivu" class="flex min-h-screen pt-16 bg-white overflow-hidden">
    <div class="flex flex-col justify-center w-full md:w-[44%] shrink-0 px-8 md:px-16 py-20">
      <p class="font-sora text-xs font-bold tracking-widest text-[#FF8F7A] uppercase mb-5">Luotettavaa laatua jo vuodesta 1967</p>
      <h1 class="font-merriweather font-normal text-[#14375A] text-5xl md:text-[3.75rem] leading-[1.15] mb-6">Kotiovelle.<br />Puhtaana.</h1>
      <p class="font-inter text-[#14375A]/65 text-base leading-relaxed mb-10 max-w-sm">
        Melers Pesulapalvelut tarjoaa laadukkaat pesu- ja tekstiilihuoltopalvelut kotiin ja yrityksille. Tervetuloa myymälään tai tilaa kuljetus.
      </p>
      <div class="flex flex-wrap items-center gap-5">
        <button
          onclick="document.dispatchEvent(new CustomEvent('open-booking'))"
          class="inline-flex items-center gap-2 bg-[#FF8F7A] text-white font-sora font-bold px-7 py-3.5 rounded-full hover:bg-[#ff7a63] transition-colors text-base"
        >
          Tilaa kuljetus →
        </button>
        <a href="#palvelut" class="inline-flex items-center gap-2 text-[#14375A] font-sora font-bold text-base hover:text-[#FF8F7A] transition-colors">
          <span class="w-9 h-9 rounded-full border border-[#14375A]/20 flex items-center justify-center text-sm shrink-0">▶</span>
          Näin se toimii
        </a>
      </div>
    </div>
    <div class="hidden md:block flex-1 relative">
      <img src="/hero-new.webp" alt="Melers Pesulapalvelut — puhtaita tekstiilejä" class="absolute inset-0 w-full h-full object-cover" fetchpriority="high" />
      <div class="absolute inset-0" style="background: linear-gradient(to right, #ffffff 0%, #ffffff 5%, transparent 40%)" />
    </div>
  </section>

  <!-- TrustBar -->
  <section class="bg-white">
    <div class="max-w-6xl mx-auto px-6 md:px-8 py-10 md:py-12 grid grid-cols-2 md:grid-cols-4 gap-y-8 md:gap-y-0">
      {trustItems.map((item, i) => (
        <div class={`flex items-start gap-3 md:gap-4 px-4 md:px-6 ${
          i === 0 ? 'pl-0 md:pl-0' :
          i === 2 ? 'pl-0 md:pl-6 md:border-l md:border-[#E9E4DF]' :
          'border-l border-[#E9E4DF]'
        }`}>
          <div class="w-10 h-10 rounded-full bg-[#F1F2F4] flex items-center justify-center shrink-0 p-2 mt-0.5">
            <img src={item.icon} alt={item.title} width="24" height="24" class="w-full h-full object-contain" style="filter: brightness(0) saturate(100%) invert(20%) sepia(30%) saturate(700%) hue-rotate(180deg)" />
          </div>
          <div>
            <h3 class="font-sora font-bold text-[#14375A] text-sm mb-1.5">{item.title}</h3>
            {item.special ? (
              <p class="font-inter text-[#14375A]/55 text-xs leading-relaxed">
                Soita meille:<br />
                <a href="tel:+35822331718" class="font-bold text-[#FF8F7A] hover:underline">+358 22 331718</a>
              </p>
            ) : (
              <p class="font-inter text-[#14375A]/55 text-xs leading-relaxed">{item.desc}</p>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- HowItWorks -->
  <section id="palvelut" class="bg-white py-20 scroll-mt-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="relative rounded-2xl overflow-hidden mb-16">
        <img src="/van.webp" alt="Melers kuljetusauto" width="1200" height="500" class="w-full h-64 md:h-80 object-cover object-center" />
        <div class="absolute inset-0 bg-[#14375A]/40 flex items-center px-10 md:px-16">
          <div>
            <p class="font-sora font-bold text-white/80 text-xs uppercase tracking-widest mb-3">Kotiinkuljetus Turussa</p>
            <p class="font-merriweather font-normal text-white text-3xl md:text-4xl mb-6">Noudamme ja toimitamme<br />suoraan ovellesi.</p>
            <button
              onclick="document.dispatchEvent(new CustomEvent('open-booking'))"
              class="inline-flex items-center gap-2 bg-[#FF8F7A] text-white font-sora font-bold px-6 py-3 rounded-full hover:bg-[#ff7a63] transition-colors text-sm"
            >
              Tilaa kuljetus →
            </button>
          </div>
        </div>
      </div>

      <div class="mb-14 text-center">
        <p class="font-sora text-xs font-bold tracking-widest text-[#FF8F7A] uppercase mb-3">Näin se toimii</p>
        <h2 class="font-merriweather font-normal text-[#14375A] text-4xl">Tilaa. Noudamme. Puhtaana takaisin.</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 relative">
        <div class="hidden md:block absolute top-8 left-[calc(16.66%+1rem)] right-[calc(16.66%+1rem)] h-px bg-[#E9E4DF]" />
        {steps.map((step) => (
          <div class="flex flex-col items-center text-center gap-5">
            <div class="w-16 h-16 rounded-full bg-[#14375A] text-white font-sora font-semibold text-xl flex items-center justify-center shrink-0 relative z-10">
              {step.num}
            </div>
            <div>
              <h3 class="font-sora font-semibold text-[#14375A] text-xl mb-2">{step.title}</h3>
              <p class="font-inter text-[#14375A]/65 text-sm leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="palvelut" class="bg-[#F1F2F4] py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8 items-center mb-12">
        <div>
          <p class="font-sora text-xs font-bold tracking-widest text-[#FF8F7A] uppercase mb-3">Palvelumme</p>
          <h2 class="font-merriweather font-normal text-[#14375A] text-4xl">Kaikki tekstiilihuolto<br />yhdestä paikasta</h2>
        </div>
        <div class="rounded-3xl overflow-hidden aspect-[4/3]">
          <img src="/photo-towels.webp" alt="Puhtaita tekstiilejä" class="w-full h-full object-cover object-[center_40%]" />
        </div>
      </div>

      <div class="grid md:grid-cols-4 gap-5">
        {services.map((s) => (
          <div class={`rounded-2xl p-7 flex flex-col gap-4 ${s.highlight ? 'bg-[#14375A] text-white' : 'bg-white text-[#14375A]'}`}>
            <div class={`w-10 h-10 rounded-xl flex items-center justify-center p-2 ${s.highlight ? 'bg-white/10' : 'bg-[#FFE6E2]'}`}>
              <img
                src={s.icon}
                alt={s.title}
                width="24" height="24"
                class="w-full h-full object-contain"
                style={s.highlight
                  ? 'filter: brightness(0) invert(1)'
                  : 'filter: brightness(0) saturate(100%) invert(63%) sepia(60%) saturate(400%) hue-rotate(320deg)'}
              />
            </div>
            <h3 class={`font-sora font-semibold text-lg ${s.highlight ? 'text-white' : 'text-[#14375A]'}`}>{s.title}</h3>
            <p class={`font-inter text-sm leading-relaxed ${s.highlight ? 'text-white/75' : 'text-[#14375A]/65'}`}>{s.desc}</p>
            <a href={s.highlight ? '/yrityksille' : '#yhteys'} class="text-sm font-sora font-bold mt-auto text-[#FF8F7A]">Lue lisää →</a>
          </div>
        ))}

        <div class="rounded-2xl bg-[#FF8F7A] text-white p-7 flex flex-col justify-between">
          <div>
            <h3 class="font-sora font-semibold text-xl mb-3">Varaa pesulapalvelu</h3>
            <p class="font-inter text-sm text-white/80 leading-relaxed mb-6">Valitse sinulle sopiva aika — me hoidamme loput.</p>
          </div>
          <div>
            <button
              onclick="document.dispatchEvent(new CustomEvent('open-booking'))"
              class="inline-flex items-center gap-2 bg-white text-[#FF8F7A] font-sora font-bold text-sm px-5 py-2.5 rounded-full hover:bg-[#FFE6E2] transition-colors"
            >
              Varaa aika →
            </button>
            <p class="mt-3 text-xs text-white/60 font-inter">⏱ Varaus vie vain 2 minuuttia</p>
          </div>
        </div>
      </div>

      <div class="mt-8 flex items-center justify-center gap-3">
        <span class="text-[#FF8F7A] text-lg">✦</span>
        <p class="font-inter text-[#14375A]/60 text-sm">
          <span class="font-sora font-bold text-[#14375A]">Tahratakuu:</span>{" "}
          Jos vaikea tahra ei lähde, pesemme uudelleen — veloituksetta.
        </p>
      </div>
    </div>
  </section>

  <!-- BasketsFeature -->
  <section class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <p class="font-sora text-xs font-bold tracking-widest text-[#FF8F7A] uppercase mb-3">Helppo asioida</p>
        <h2 class="font-merriweather font-normal text-[#14375A] text-4xl">Valitse sinulle sopiva tapa</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-[#F1F2F4] rounded-3xl p-10 flex flex-col gap-5">
          <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center shrink-0 p-3">
            <img src="/icons/Artboard_10.svg" alt="" width="28" height="28" class="w-full h-full object-contain" style="filter: brightness(0) saturate(100%) invert(20%) sepia(30%) saturate(700%) hue-rotate(180deg)" />
          </div>
          <div>
            <h3 class="font-sora font-semibold text-[#14375A] text-2xl mb-2">Tuo myymälään</h3>
            <p class="font-inter text-[#14375A]/65 text-base leading-relaxed">Käy myymälässämme Turun keskustassa. Jätä vaatteet — hoidamme loput.</p>
          </div>
          <div class="flex flex-col gap-1.5 font-inter text-sm text-[#14375A]/60">
            <p>Kaskenkatu 12, Turku</p>
            <p>Ma–pe 10–17 · La 10–14</p>
            <p class="text-xs text-[#14375A]/40 mt-1">Valmis 4–8 päivässä</p>
          </div>
        </div>

        <div class="bg-[#14375A] rounded-3xl p-10 flex flex-col gap-5">
          <div class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center shrink-0 p-3">
            <img src="/icons/Artboard_7.svg" alt="" width="28" height="28" class="w-full h-full object-contain" style="filter: brightness(0) invert(1)" />
          </div>
          <div>
            <h3 class="font-sora font-semibold text-white text-2xl mb-2">Kotiinkuljetus</h3>
            <p class="font-inter text-white/70 text-base leading-relaxed">Noudamme tekstiilisi oveltasi ja toimitamme puhtaana takaisin. Turku ja lähikunnat.</p>
          </div>
          <div class="mt-auto">
            <p class="font-sora font-bold text-[#FF8F7A] text-2xl mb-4">
              <span class="font-inter font-normal text-white/50 text-xs mr-1">alk.</span>10,99€<span class="font-inter font-normal text-white/50 text-sm">/suunta</span>
            </p>
            <button
              onclick="document.dispatchEvent(new CustomEvent('open-booking'))"
              class="inline-flex items-center gap-2 bg-[#FF8F7A] text-white font-sora font-bold px-6 py-3 rounded-full hover:bg-[#ff7a63] transition-colors text-sm"
            >
              Tilaa nouto →
            </button>
            <p class="text-xs text-white/35 mt-3">Valmis 4–8 päivässä</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TeamSection -->
  <section class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="flex justify-center md:justify-start">
          <div class="w-72 rounded-2xl overflow-hidden shadow-md">
            <img src="/team.webp" alt="Melersin tiimi" width="288" height="216" class="w-full h-auto object-cover" />
          </div>
        </div>
        <div>
          <p class="font-sora text-xs font-bold tracking-widest text-[#FF8F7A] uppercase mb-3">Tiimimme</p>
          <h2 class="font-merriweather font-normal text-[#14375A] text-4xl mb-5">Teitä palvelevat</h2>
          <p class="font-inter text-[#14375A]/65 text-base leading-relaxed mb-8">
            Tiimimme yhteenlaskettu kokemus pesulaalalta on yli <span class="font-semibold text-[#14375A]">79 vuotta</span>. Jokainen tekstiili käsitellään ihmiseltä ihmiselle, ammattitaidolla.
          </p>
          <a href="/meista" class="font-sora font-bold text-sm text-[#14375A] hover:text-[#FF8F7A] transition-colors">
            Tutustu tarinamme →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="bg-[#E9E4DF] py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="font-sora text-xs font-bold tracking-widest text-[#FF8F7A] uppercase mb-3">Asiakkaiden sanoin</p>
        <h2 class="font-merriweather font-normal text-[#14375A] text-4xl">Mitä asiakkaamme sanovat</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {testimonials.map((t) => (
          <div class="bg-white rounded-2xl p-8 flex flex-col gap-6">
            <div class="flex gap-1">
              {[0,1,2,3,4].map((j) => (
                <svg key={j} width="16" height="16" viewBox="0 0 24 24" fill="#FF8F7A">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                </svg>
              ))}
            </div>
            <p class="font-inter text-[#14375A]/75 text-sm leading-relaxed flex-1">"{t.quote}"</p>
            <div class="flex items-center gap-3 pt-2 border-t border-[#E9E4DF]">
              <div class="w-9 h-9 rounded-full bg-[#DDE7F0] flex items-center justify-center font-sora font-bold text-[#14375A] text-sm shrink-0">
                {t.name[0]}
              </div>
              <div>
                <p class="font-sora font-bold text-[#14375A] text-sm">{t.name}</p>
                <p class="font-inter text-[#14375A]/50 text-xs">{t.location}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WhyMelers -->
  <section class="bg-[#E9E4DF] py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8 items-stretch">
        <div class="rounded-3xl overflow-hidden min-h-[380px]">
          <iframe
            src="https://maps.google.com/maps?q=Kaskenkatu+12,+20700+Turku,+Finland&z=16&output=embed"
            width="100%"
            height="100%"
            style="border: 0; min-height: 380px"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Melers Pesulapalvelut — Kaskenkatu 12, Turku"
          ></iframe>
        </div>
        <div class="bg-[#14375A] rounded-3xl p-10 flex flex-col justify-between">
          <div>
            <p class="font-sora text-xs font-bold tracking-widest text-[#FF8F7A] uppercase mb-4">Tarjous uusille asiakkaille</p>
            <h2 class="font-merriweather font-normal text-white text-3xl md:text-4xl mb-5">Ensimmäinen nouto ilmaiseksi</h2>
            <p class="font-inter text-white/70 text-base leading-relaxed mb-2">Uusille asiakkaille: ensimmäinen noutokerta veloituksetta. Kokeile kotiinkuljetuspalvelua ilman riskiä.</p>
          </div>
          <div class="mt-8">
            <button
              onclick="document.dispatchEvent(new CustomEvent('open-booking'))"
              class="inline-flex items-center gap-2 bg-[#FF8F7A] text-white font-sora font-bold px-7 py-3.5 rounded-full hover:bg-[#ff7a63] transition-colors text-sm"
            >
              Tilaa ilmainen nouto →
            </button>
            <div class="mt-6 pt-6 border-t border-white/10">
              <p class="font-sora font-semibold text-white text-sm mb-1">Kaskenkatu 12, Turku</p>
              <p class="font-inter text-white/50 text-xs">Ma–pe 10–17 · La 10–14</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ContactCTA -->
  <section id="yhteys" class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-start">
      <div>
        <p class="font-sora text-xs font-bold tracking-widest text-[#FF8F7A] uppercase mb-4">Ota Yhteyttä</p>
        <h2 class="font-merriweather font-normal text-[#14375A] text-4xl mb-6">Varaa aika tai<br />pyydä tarjous</h2>
        <p class="font-inter text-[#14375A]/65 text-base leading-relaxed mb-10">
          Jätä yhteystietosi niin otamme yhteyttä mahdollisimman pian. Yritysasiakkaat — pyydä tarjous niin räätälöimme teille sopivan ratkaisun.
        </p>
        <div class="flex flex-col gap-5">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-[#FFE6E2] flex items-center justify-center text-[#FF8F7A] text-sm shrink-0">✦</div>
            <div>
              <p class="font-sora font-bold text-[#14375A] text-sm">Sijainti</p>
              <p class="font-inter text-[#14375A]/60 text-sm">Turku, Finland — Kaskenkatu 12</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-[#FFE6E2] flex items-center justify-center text-[#FF8F7A] text-sm shrink-0">✦</div>
            <div>
              <p class="font-sora font-bold text-[#14375A] text-sm">Palvelualue</p>
              <p class="font-inter text-[#14375A]/60 text-sm">Turku ja lähikunnat</p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-[#F1F2F4] rounded-3xl p-8">
        <form class="flex flex-col gap-5" action="/yhteys">
          <div class="grid grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label class="font-sora text-xs font-bold text-[#14375A]">Nimi</label>
              <input type="text" placeholder="Etunimi Sukunimi" class="bg-white border border-[#E9E4DF] rounded-xl px-4 py-3 font-inter text-sm text-[#14375A] placeholder-[#14375A]/30 outline-none focus:border-[#FF8F7A] transition-colors" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="font-sora text-xs font-bold text-[#14375A]">Yritys (valinnainen)</label>
              <input type="text" placeholder="Yrityksen nimi" class="bg-white border border-[#E9E4DF] rounded-xl px-4 py-3 font-inter text-sm text-[#14375A] placeholder-[#14375A]/30 outline-none focus:border-[#FF8F7A] transition-colors" />
            </div>
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="font-sora text-xs font-bold text-[#14375A]">Sähköposti</label>
            <input type="email" placeholder="sinä@esimerkki.fi" class="bg-white border border-[#E9E4DF] rounded-xl px-4 py-3 font-inter text-sm text-[#14375A] placeholder-[#14375A]/30 outline-none focus:border-[#FF8F7A] transition-colors" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="font-sora text-xs font-bold text-[#14375A]">Palvelu</label>
            <select class="bg-white border border-[#E9E4DF] rounded-xl px-4 py-3 font-inter text-sm text-[#14375A] outline-none focus:border-[#FF8F7A] transition-colors appearance-none">
              <option value="">Valitse palvelu</option>
              <option>Pyykinpesu</option>
              <option>Tekstiilihuolto</option>
              <option>Yrityspalvelut / Tarjouspyyntö</option>
              <option>Muu</option>
            </select>
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="font-sora text-xs font-bold text-[#14375A]">Viesti (valinnainen)</label>
            <textarea rows="3" placeholder="Kerro lisää tarpeistasi..." class="bg-white border border-[#E9E4DF] rounded-xl px-4 py-3 font-inter text-sm text-[#14375A] placeholder-[#14375A]/30 outline-none focus:border-[#FF8F7A] transition-colors resize-none"></textarea>
          </div>
          <a href="/yhteys" class="block w-full text-center bg-[#FF8F7A] text-white font-sora font-bold py-3.5 rounded-full hover:bg-[#ff7a63] transition-colors">
            Lähetä →
          </a>
          <p class="font-inter text-xs text-[#14375A]/40 text-center">Vastaamme 1 arkipäivän kuluessa.</p>
        </form>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-[#14375A] text-white">
    <div class="max-w-6xl mx-auto px-6 py-12">
      <div class="grid md:grid-cols-3 gap-10 mb-10">
        <div>
          <div class="mb-4">
            <img src="/logo-footer-transparent.webp" alt="Melers Pesulapalvelut" width="110" height="110" class="w-[110px] h-auto" />
          </div>
          <p class="font-inter text-white/60 text-base leading-relaxed">Kotiovelle. Puhtaana.<br />Turussa vuodesta 1967.</p>
        </div>
        <div>
          <p class="font-sora font-bold text-white/50 text-base uppercase tracking-widest mb-4">Sivut</p>
          <ul class="flex flex-col gap-2.5">
            {[
              { label: 'Etusivu', href: '/' },
              { label: 'Palvelut', href: '/palvelut' },
              { label: 'Hinnasto', href: '/hinnasto' },
              { label: 'Yrityksille', href: '/yrityksille' },
              { label: 'Meistä', href: '/meista' },
              { label: 'Ota Yhteyttä', href: '/yhteys' },
            ].map((l) => (
              <li><a href={l.href} class="font-inter text-white/60 text-base hover:text-white transition-colors">{l.label}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <p class="font-sora font-bold text-white/50 text-base uppercase tracking-widest mb-4">Yhteystiedot</p>
          <div class="flex flex-col gap-2.5 font-inter text-white/60 text-base">
            <p>Kaskenkatu 12, 20700 Turku</p>
            <p>Ma–pe 10–17 · La 10–14</p>
            <p class="text-white/40 text-base">Yritysasiakkaat: ma–pe 6–17</p>
            <a href="tel:+35822331718" class="text-[#FF8F7A] hover:text-[#FFE6E2] transition-colors">+358 22 331718</a>
            <a href="/yhteys" class="text-[#FF8F7A] hover:text-[#FFE6E2] transition-colors">Ota yhteyttä →</a>
          </div>
        </div>
      </div>
      <div class="border-t border-white/10 pt-6 flex flex-col md:flex-row justify-between items-center gap-3">
        <p class="font-inter text-white/30 text-base">© {year} Melers Pesulapalvelut Oy. Kaikki oikeudet pidätetään.</p>
        <p class="font-inter text-white/20 text-base italic">Kotiovelle. Puhtaana.</p>
      </div>
    </div>
  </footer>

</Layout>
