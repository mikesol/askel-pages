---
import Layout from '../layouts/Layout.astro'

const steps = [
  { num: '1', title: 'Tilaa nouto tai tuo itse', body: 'Tilaa nouto ottamalla yhteyttä — sovitaan aika ja kerrot mitä pestään. Tai tuo suoraan myymälään: Kaskenkatu 12, ma–pe 10–17, la 10–14.' },
  { num: '2', title: 'Me noudamme', body: 'Tulemme kotiovellesi sovittuna aikana. Ei tarvitse lajitella — hoidamme sen puolestasi.' },
  { num: '3', title: 'Palautamme puhtaana', body: 'Sovimme toimituspäivän ja -ajan etukäteen. Soitamme noin tunnin ennen saapumista.' },
]
---

<Layout title="Palvelut — Melers Pesulapalvelut" description="Pyykinpesu, kemiallinen pesu ja yrityspalvelut Turussa. Nouto ja toimitus kotiovelle. Yli 79 vuoden kokemus.">
  <div class="pt-16">

    <section class="bg-[#14375A] pt-20 pb-16">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <p class="font-sora text-xs font-bold tracking-widest text-[#FF8F7A] uppercase mb-4">Palvelumme</p>
        <h1 class="font-merriweather font-normal text-white text-4xl md:text-5xl leading-snug mb-4">Kaikki tekstiilihuolto<br />samasta paikasta</h1>
        <p class="font-inter text-white/65 text-base leading-relaxed max-w-xl mx-auto">
          Pyykinpesusta kemialliseen pesuun — noudamme, pesemme, viikkaamme ja palautamme. Nouto ja toimitus alk. 10,99 € / suunta.
        </p>
      </div>
    </section>

    <section class="bg-[#F1F2F4] py-20">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-14">
          <p class="font-sora text-xs font-bold tracking-widest text-[#FF8F7A] uppercase mb-3">Näin se toimii</p>
          <h2 class="font-merriweather font-normal text-[#14375A] text-3xl md:text-4xl">Kolme vaihetta riittää</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          {steps.map((step) => (
            <div class="bg-white rounded-3xl p-8">
              <div class="w-10 h-10 rounded-full bg-[#14375A] flex items-center justify-center mb-5">
                <span class="font-sora font-bold text-sm text-white">{step.num}</span>
              </div>
              <h3 class="font-sora font-bold text-[#14375A] text-base mb-2">{step.title}</h3>
              <p class="font-inter text-[#14375A]/65 text-sm leading-relaxed mb-3">{step.body}</p>
              {step.num === '1' && (
                <div class="flex flex-col gap-1.5 mt-1">
                  <a href="tel:+35822331718" class="font-sora font-bold text-xs text-[#FF8F7A] hover:text-[#ff7a63] transition-colors">(02) 233 1718</a>
                  <a href="mailto:myynti@melers.fi" class="font-sora font-bold text-xs text-[#FF8F7A] hover:text-[#ff7a63] transition-colors">myynti@melers.fi</a>
                </div>
              )}
            </div>
          ))}
        </div>
        <div class="mt-12 rounded-3xl overflow-hidden">
          <img src="/van.webp" alt="Melers Pesulapalvelut — nouto ja toimitus" width="1200" height="500" class="w-full object-cover object-center max-h-64 md:max-h-80" />
        </div>
        <p class="text-center font-inter text-sm text-[#14375A]/50 mt-8">Ensimmäinen nouto on ilmainen — kokeile huoletta.</p>
      </div>
    </section>

    <section id="pyykinpesu" class="bg-white py-20">
      <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-start">
        <div>
          <p class="font-sora text-xs font-bold tracking-widest text-[#FF8F7A] uppercase mb-2">01</p>
          <h2 class="font-merriweather font-normal text-[#14375A] text-4xl mb-3">Pyykinpesu</h2>
          <p class="font-sora font-bold text-sm text-[#FF8F7A] mb-4">Arjen tekstiilit huolella hoidettu</p>
          <p class="font-inter text-base leading-relaxed text-[#14375A]/65 mb-8">
            Paidat, lakanat, pyyhkeet, peitot, matot — kaikki samalla tilauksella. Noudamme, pesemme ammattimaisesti ja toimitamme takaisin puhtaana. Hinnoittelu kilon mukaan, minimitilaus 4 kg.
          </p>
          <div class="flex flex-wrap gap-6 mb-8 p-4 rounded-2xl bg-[#F1F2F4]">
            <div class="text-center">
              <p class="font-sora font-bold text-xs uppercase tracking-widest mb-1 text-[#14375A]/40">Toimitusaika</p>
              <p class="font-sora font-bold text-sm text-[#14375A]">4–8 päivässä</p>
            </div>
            <div class="w-px bg-[#E9E4DF]"></div>
            <div class="text-center">
              <p class="font-sora font-bold text-xs uppercase tracking-widest mb-1 text-[#14375A]/40">Minimitilaus</p>
              <p class="font-sora font-bold text-sm text-[#14375A]">4 kg</p>
            </div>
            <div class="w-px bg-[#E9E4DF]"></div>
            <div class="text-center">
              <p class="font-sora font-bold text-xs uppercase tracking-widest mb-1 text-[#14375A]/40">Kuljetus</p>
              <p class="font-sora font-bold text-sm text-[#14375A]">alk. 10,99 €</p>
            </div>
          </div>
          <div class="flex flex-wrap gap-3 items-center">
            <button onclick="document.dispatchEvent(new CustomEvent('open-booking'))" class="inline-flex items-center gap-2 bg-[#FF8F7A] text-white font-sora font-bold px-7 py-3.5 rounded-full hover:bg-[#ff7a63] transition-colors text-sm">
              Tilaa nouto →
            </button>
            <a href="/hinnasto#vesipesu" class="inline-flex items-center gap-2 text-[#14375A]/60 font-sora font-bold text-sm hover:text-[#14375A] transition-colors">
              Katso hinnat →
            </a>
          </div>
        </div>
        <div class="rounded-3xl overflow-hidden bg-[#F1F2F4]">
          <div class="overflow-hidden max-h-52">
            <img src="/photo-towels.webp" alt="Puhtaita tekstiilejä — Melers Pesulapalvelut" width="800" height="400" class="w-full object-cover object-left" />
          </div>
          <div class="p-8">
            <p class="font-sora font-bold text-xs uppercase tracking-widest mb-5 text-[#FF8F7A]">Mitä sisältyy</p>
            <ul class="flex flex-col gap-4">
              {[
                'Liinavaatteet: pesu, mankeli ja viikkaus',
                'Käyttövaatteet: pesu, silitys ja viikkaus',
                'Tahratakuu — jos tahra ei lähde, pesemme uudelleen veloituksetta',
                'Nouto ja toimitus kotiovelle alk. 10,99 € / suunta',
                'Voit myös tuoda myymälään — Kaskenkatu 12, Turku',
                'Palveluseteli hyväksytty maksuvälineenä (ALV 0 %)',
              ].map((d) => (
                <li class="flex items-start gap-3">
                  <span class="text-[#FF8F7A] shrink-0 mt-0.5">✦</span>
                  <span class="font-inter text-sm leading-relaxed text-[#14375A]/75">{d}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section id="kemiallinen-pesu" class="bg-[#F1F2F4] py-20">
      <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-start md:[&>*:first-child]:order-2">
        <div>
          <p class="font-sora text-xs font-bold tracking-widest text-[#FF8F7A] uppercase mb-2">02</p>
          <h2 class="font-merriweather font-normal text-[#14375A] text-4xl mb-3">Kemiallinen pesu</h2>
          <p class="font-sora font-bold text-sm text-[#FF8F7A] mb-4">Juhlavaatteet ja takit oikein käsiteltyinä</p>
          <p class="font-inter text-base leading-relaxed text-[#14375A]/65 mb-8">
            Puvut, juhlavaatteet, takit ja silkki — herkät tekstiilit puhdistetaan kemiallisesti ilman vettä. Muoto ja väri säilyvät, materiaalin rakenne pysyy ehjänä. Hinnoittelu kappaleittain.
          </p>
          <div class="flex flex-wrap gap-6 mb-8 p-4 rounded-2xl bg-white">
            <div class="text-center">
              <p class="font-sora font-bold text-xs uppercase tracking-widest mb-1 text-[#14375A]/40">Toimitusaika</p>
              <p class="font-sora font-bold text-sm text-[#14375A]">4–8 päivässä</p>
            </div>
            <div class="w-px bg-[#E9E4DF]"></div>
            <div class="text-center">
              <p class="font-sora font-bold text-xs uppercase tracking-widest mb-1 text-[#14375A]/40">Hinnoittelu</p>
              <p class="font-sora font-bold text-sm text-[#14375A]">Per kappale</p>
            </div>
          </div>
          <a href="/yhteys" class="inline-flex items-center gap-2 bg-[#FF8F7A] text-white font-sora font-bold px-7 py-3.5 rounded-full hover:bg-[#ff7a63] transition-colors text-sm">Kysy lisää →</a>
          <a href="/hinnasto#juhlavaatteet" class="inline-flex items-center gap-2 ml-4 text-[#14375A]/60 font-sora font-bold text-sm hover:text-[#14375A] transition-colors">Katso hinnat →</a>
        </div>
        <div class="rounded-3xl overflow-hidden bg-white">
          <div class="overflow-hidden max-h-52">
            <img src="/photo-dry-cleaning-2.webp" alt="Kemiallinen pesu — Melers Pesulapalvelut" width="800" height="400" class="w-full object-cover object-center" />
          </div>
          <div class="p-8">
            <p class="font-sora font-bold text-xs uppercase tracking-widest mb-5 text-[#FF8F7A]">Mitä sisältyy</p>
            <ul class="flex flex-col gap-4">
              {[
                'Materiaalitarkistus ennen käsittelyä',
                'Kemiallinen puhdistus liuottimilla (ei vettä)',
                'Silitys ja muotoilu käsittelyn jälkeen',
                'Suojapussitus ja huolellinen pakkaus',
                'Morsiuspuvut, frakkipuvut ja erikoisvaatteet',
              ].map((d) => (
                <li class="flex items-start gap-3">
                  <span class="text-[#FF8F7A] shrink-0 mt-0.5">✦</span>
                  <span class="font-inter text-sm leading-relaxed text-[#14375A]/75">{d}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section id="yrityspalvelut" class="bg-[#DDE7F0] py-20">
      <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-start">
        <div>
          <p class="font-sora text-xs font-bold tracking-widest text-[#FF8F7A] uppercase mb-2">03</p>
          <h2 class="font-merriweather font-normal text-[#14375A] text-4xl mb-3">Yrityspalvelut</h2>
          <p class="font-sora font-bold text-sm text-[#FF8F7A] mb-4">Luotettava kumppani yrityksellesi</p>
          <p class="font-inter text-base leading-relaxed text-[#14375A]/65 mb-5">
            Pesemme vuosittain yli 170 000 kg tekstiilejä hoivakodeille, hotelleille ja yrityksille. Säännölliset noudot, volyymipohjainen hinnoittelu ja nimetty palvelupäällikkö — yksi sopimus, ei huolia.
          </p>
          <div class="flex flex-wrap gap-2 mb-8">
            {['Hoivakodit', 'Hotellit', 'Ravintolat', 'Toimistot'].map((s) => (
              <span class="font-sora font-bold text-xs text-[#14375A]/60 border border-[#14375A]/20 rounded-full px-3 py-1">{s}</span>
            ))}
          </div>
          <a href="/yrityksille" class="inline-flex items-center gap-2 bg-[#14375A] text-white font-sora font-bold px-7 py-3.5 rounded-full hover:bg-[#0f2a45] transition-colors text-sm">
            Pyydä tarjous →
          </a>
        </div>
        <div class="rounded-3xl overflow-hidden bg-white">
          <div class="overflow-hidden max-h-52">
            <img src="/photo-hotel.webp" alt="Yrityspalvelut — Melers Pesulapalvelut" width="800" height="400" class="w-full object-cover object-center" />
          </div>
          <div class="p-8">
            <p class="font-sora font-bold text-xs uppercase tracking-widest mb-5 text-[#FF8F7A]">Mitä sisältyy</p>
            <ul class="flex flex-col gap-4">
              {[
                'Räätälöity nouto- ja toimitusaikataulu',
                'Volyymipohjainen hinnoittelu',
                'Hygieniastandardit täytetty (hoiva-ala)',
                'Liinavaatevuokraus pitkäaikaisasiakkaille — liinavaatteet ja pyyhkeet',
                'Nimetty palvelupäällikkö',
              ].map((d) => (
                <li class="flex items-start gap-3">
                  <span class="text-[#FF8F7A] shrink-0 mt-0.5">✦</span>
                  <span class="font-inter text-sm leading-relaxed text-[#14375A]/75">{d}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-[#FF8F7A] py-16">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="font-merriweather font-normal text-white text-3xl md:text-4xl mb-4">Etkö ole varma mitä tarvitset?</h2>
        <p class="font-inter text-white/80 text-base leading-relaxed mb-8">Kerromme mielellämme mikä palvelu sopii tilanteeseen parhaiten.</p>
        <a href="/yhteys" class="inline-flex items-center gap-2 bg-white text-[#FF8F7A] font-sora font-bold px-8 py-4 rounded-full hover:bg-[#FFE6E2] transition-colors">
          Ota yhteyttä →
        </a>
      </div>
    </section>

  </div>

  <footer class="bg-[#14375A] text-white">
    <div class="max-w-6xl mx-auto px-6 py-12">
      <div class="grid md:grid-cols-3 gap-10 mb-10">
        <div>
          <div class="mb-4"><img src="/logo-footer-transparent.webp" alt="Melers Pesulapalvelut" width="110" height="110" class="w-[110px] h-auto" /></div>
          <p class="font-inter text-white/60 text-base leading-relaxed">Kotiovelle. Puhtaana.<br />Turussa vuodesta 1967.</p>
        </div>
        <div>
          <p class="font-sora font-bold text-white/50 text-base uppercase tracking-widest mb-4">Sivut</p>
          <ul class="flex flex-col gap-2.5">
            {[{label:'Etusivu',href:'/'},{label:'Palvelut',href:'/palvelut'},{label:'Hinnasto',href:'/hinnasto'},{label:'Yrityksille',href:'/yrityksille'},{label:'Meistä',href:'/meista'},{label:'Ota Yhteyttä',href:'/yhteys'}].map((l) => (
              <li><a href={l.href} class="font-inter text-white/60 text-base hover:text-white transition-colors">{l.label}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <p class="font-sora font-bold text-white/50 text-base uppercase tracking-widest mb-4">Yhteystiedot</p>
          <div class="flex flex-col gap-2.5 font-inter text-white/60 text-base">
            <p>Kaskenkatu 12, 20700 Turku</p>
            <p>Ma–pe 10–17 · La 10–14</p>
            <a href="tel:+35822331718" class="text-[#FF8F7A] hover:text-[#FFE6E2] transition-colors">+358 22 331718</a>
          </div>
        </div>
      </div>
      <div class="border-t border-white/10 pt-6">
        <p class="font-inter text-white/30 text-base">© {new Date().getFullYear()} Melers Pesulapalvelut Oy. Kaikki oikeudet pidätetään.</p>
      </div>
    </div>
  </footer>
</Layout>
